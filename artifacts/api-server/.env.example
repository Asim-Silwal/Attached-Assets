# Copy this file to .env and fill in the values before running the API server.
# Use a Gmail account with an App Password for secure SMTP delivery.

NODE_ENV=development
PORT=4000
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
CONTACT_RECEIVER=digital.vertex26@gmail.com
GOOGLE_SHEETS_SPREADSHEET_ID=your-google-sheet-id
GOOGLE_SHEETS_SHEET_NAME=Leads
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
## OAuth2 (preferred)
# To use OAuth2, generate credentials and refresh token and set these values.
GMAIL_OAUTH_CLIENT_ID=your-google-oauth-client-id
GMAIL_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_OAUTH_REFRESH_TOKEN=your-google-oauth-refresh-token
